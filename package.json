{
  "name": "toastr-next",
  "version": "3.0.0",
  "description": "Zero-dependency toast notifications. TypeScript rewrite of toastr 2.x — CSS animations, dark mode, Promise API, fully accessible.",
  "type": "module",
  "main": "./dist/toastr-next.cjs.js",
  "module": "./dist/toastr-next.es.js",
  "exports": {
    ".": {
      "import": "./dist/toastr-next.es.js",
      "require": "./dist/toastr-next.cjs.js",
      "browser": "./dist/toastr-next.iife.js"
    },
    "./react": {
      "import": "./dist/toastr-next.react.es.js",
      "require": "./dist/toastr-next.react.cjs.js"
    },
    "./style": "./dist/toastr-next.css"
  },
  "types": "./dist/types/index.d.ts",
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --emitDeclarationOnly && vite build && vite build --config vite.config.react.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "toastr",
    "toast",
    "notifications",
    "typescript",
    "zero-dependency",
    "accessible",
    "dark-mode"
  ],
  "homepage": "https://github.com/Divyesh-5981/toastr-next",
  "repository": {
    "type": "git",
    "url": "https://github.com/Divyesh-5981/toastr-next"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^1.5.0",
    "jsdom": "^24.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
